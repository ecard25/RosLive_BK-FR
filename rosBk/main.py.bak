from contextlib import asynccontextmanager
from fastapi import FastAPI, Depends, HTTPException, status
from fastapi.middleware.cors import CORSMiddleware
from sqlalchemy.orm import Session
from pydantic import BaseModel
import httpx

# Importación estricta de tus módulos locales de arquitectura
from database import init_db, get_db, UsuarioModel
from security import (
    obtener_hash_contrasena, 
    verificar_contrasena, 
    crear_token_acceso, 
    obtener_usuario_actual
)

# Definición de la constante global con la API KEY de Whereby
WHEREBY_API_KEY = "TU_API_KEY_DE_WHEREBY_AQUÍ"

@asynccontextmanager
async def lifespan(app: FastAPI):
    """
    Lifespan context manager de FastAPI para inicializar recursos 
    antes de aceptar peticiones, asegurando la existencia de esquemas en Postgres.
    """
    init_db()
    yield

# Inicializar FastAPI con su ciclo de vida desacoplado
app = FastAPI(
    title="Plataforma de Sala Virtual Backend", 
    description="API para gestión de usuarios (PWA) y creación de salas en Whereby usando Username plano",
    lifespan=lifespan
)

# CONFIGURACIÓN CRÍTICA DE CORS (Puente seguro entre puertos de desarrollo)
origins = [
    "http://localhost:8080",
    "http://127.0.0.1:8080",
]

app.add_middleware(
    CORSMiddleware,
    allow_origins=origins,        # Autoriza explícitamente a tu PWA
    allow_credentials=True,
    allow_methods=["*"],          # Autoriza todos los verbos HTTP (POST, GET, OPTIONS)
    allow_headers=["*"],          # Autoriza todas las cabeceras (Authorization, Content-Type)
)

# ----------------- ESQUEMAS DE VALIDACIÓN PYDANTIC -----------------

class UsuarioPeticion(BaseModel):
    """Esquema para login y registro que valida la estructura JSON de la PWA."""
    usuario: str
    contrasena: str


# --------------------- ENDPOINTS DE LA API ---------------------

@app.post("/api/usuarios/registro", status_code=status.HTTP_201_CREATED)
def registrar_usuario(usuario_data: UsuarioPeticion, db: Session = Depends(get_db)):
    """
    Registra un nuevo usuario cifrando su contraseña.
    Valida la unicidad del string plano (username) en PostgreSQL.
    """
    usuario_existente = db.query(UsuarioModel).filter(
        UsuarioModel.usuario == usuario_data.usuario
    ).first()
    
    if usuario_existente:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="El nombre de usuario ya está en uso."
        )
        
    # Cifrado de credenciales usando el nuevo motor bcrypt nativo compatible con Python 3.13
    hash_password = obtener_hash_contrasena(usuario_data.contrasena)
    
    nuevo_usuario = UsuarioModel(
        usuario=usuario_data.usuario,
        contrasena_hash=hash_password
    )
    
    db.add(nuevo_usuario)
    db.commit()
    db.refresh(nuevo_usuario)
    
    return {"mensaje": "Usuario registrado con éxito", "id": nuevo_usuario.id, "usuario": nuevo_usuario.usuario}


@app.post("/api/usuarios/login")
def login_usuario(usuario_data: UsuarioPeticion, db: Session = Depends(get_db)):
    """
    Valida las credenciales contra Postgres y genera un Token JWT firmado.
    Utiliza el claim estándar 'sub' mapeado al nombre de usuario plano.
    """
    usuario_db = db.query(UsuarioModel).filter(
        UsuarioModel.usuario == usuario_data.usuario
    ).first()
    
    # Validación matemática de existencia y verificación del hash de contraseña
    if not usuario_db or not verificar_contrasena(usuario_data.contrasena, usuario_db.contrasena_hash):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Nombre de usuario o contraseña incorrectos.",
            headers={"WWW-Authenticate": "Bearer"},
        )
        
    # ALINEACIÓN ARQUITECTÓNICA CRÍTICA: Guardamos el username en 'sub' para que lo lea security.py
    token = crear_token_acceso(data={"sub": usuario_db.usuario})
    
    # Retornamos el estándar OAuth2 exacto que procesa el login.html corregido
    return {"access_token": token, "token_type": "bearer"}


@app.get("/api/clase/verificar-acceso")
def verificar_acceso(usuario_actual: UsuarioModel = Depends(obtener_usuario_actual)):
    """
    Ruta protegida por Token JWT. Valida la vigencia y retorna la identidad de Postgres.
    """
    return {
        "mensaje": "Acceso verificado",
        "id_usuario": usuario_actual.id,
        "usuario": usuario_actual.usuario
    }


@app.post("/api/clase/crear-sala")
async def crear_sala(usuario_actual: UsuarioModel = Depends(obtener_usuario_actual)):
    """
    Ruta protegida por Token JWT. Realiza la petición asíncrona a la API externa de Whereby
    para generar una sala con bloqueo por defecto e inyectar la URL devuelta en la PWA.
    """
    whereby_url = "https://api.whereby.dev/v1/meetings"
    headers = {
        "Authorization": f"Bearer {WHEREBY_API_KEY}",
        "Content-Type": "application/json"
    }
    payload = {
        "isLocked": True,
        "roomNamePrefix": "/sala-",
        "endDate": "2026-12-31T23:59:59Z"
    }
    
    async with httpx.AsyncClient() as client:
        try:
            response = await client.post(whereby_url, json=payload, headers=headers, timeout=10.0)
            response.raise_for_status()
            
            data = response.json()
            return {
                "roomUrl": data.get("roomUrl"),
                "hostRoomUrl": data.get("hostRoomUrl")
            }
        except httpx.HTTPStatusError as exc:
            raise HTTPException(
                status_code=exc.response.status_code,
                detail=f"Error al integrar con Whereby: {exc.response.text}"
            )
        except Exception as e:
            raise HTTPException(
                status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
                detail=f"Error inesperado al contactar Whereby: {str(e)}"
            )